<Page x:Class="OctoCompendium.Presentation.MatchResultPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:OctoCompendium.Presentation"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource BackgroundBrush}">

  <Grid utu:SafeArea.Insets="VisibleBounds">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <utu:NavigationBar Content="Match Results" />

    <!-- Uploaded image preview -->
    <Border Grid.Row="1"
            Margin="16,8"
            CornerRadius="12"
            Background="{ThemeResource SurfaceVariantBrush}"
            HorizontalAlignment="Center"
            MaxWidth="200" MaxHeight="200">
      <Image x:Name="UploadedImage"
             Stretch="Uniform" />
    </Border>

    <TextBlock Grid.Row="1"
               Text="Your Photo"
               HorizontalAlignment="Center"
               VerticalAlignment="Bottom"
               Margin="0,0,0,12"
               Opacity="0.6" FontSize="12" />

    <!-- Match results list -->
    <ListView Grid.Row="2"
              ItemsSource="{Binding Matches}"
              SelectedItem="{Binding SelectedMatch, Mode=TwoWay}"
              SelectionMode="Single"
              Padding="16">
      <ListView.Header>
        <TextBlock Text="Possible Matches"
                   FontWeight="SemiBold"
                   FontSize="14"
                   Opacity="0.7"
                   Margin="12,4,12,8" />
      </ListView.Header>
      <ListView.ItemTemplate>
        <DataTemplate>
          <Grid Padding="8" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Width="56" Height="56"
                    Background="{ThemeResource SurfaceVariantBrush}"
                    CornerRadius="8">
              <Image Source="{Binding StickerImageUri}"
                     Stretch="UniformToFill" />
            </Border>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
              <TextBlock Text="{Binding Sticker.Name}" FontWeight="SemiBold" />
              <TextBlock Text="{Binding Sticker.Category}"
                         Opacity="0.6" FontSize="12" />
            </StackPanel>

            <TextBlock Grid.Column="2"
                       VerticalAlignment="Center"
                       Opacity="0.7">
              <Run Text="{Binding Confidence, Converter={StaticResource PercentConverter}}" />
            </TextBlock>
          </Grid>
        </DataTemplate>
      </ListView.ItemTemplate>
    </ListView>

    <Button Grid.Row="3"
            Content="✅ Confirm Match"
            Command="{Binding ConfirmMatchCommand}"
            HorizontalAlignment="Stretch"
            Margin="16"
            Style="{StaticResource FilledButtonStyle}" />
  </Grid>
</Page>
